{
  "expo": {
    "name": "Pantry Planner",
    "slug": "pantry-planner-mobile",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/be-logo.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "orientation": "portrait",
    "icon": "./assets/be-logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/be-logo.png",
        "backgroundColor": "#09090b"
      }
    }
  }
}
